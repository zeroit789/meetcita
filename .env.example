APP_NAME="Appointments"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# EN: 'es' (Spanish) or 'en' (English) — the booking UI supports both.
# ES: 'es' (español) o 'en' (inglés) — la UI de reservas soporta ambos.
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ==============================================================================
# APPOINTMENTS — Booking system settings / Ajustes del sistema de reservas
# ==============================================================================
# EN: Fill these with YOUR data. None of these are required for the system to
#     boot (it degrades gracefully), but you need them for the full experience.
# ES: Rellena con TUS datos. Nada de esto es obligatorio para arrancar (degrada
#     con gracia), pero lo necesitas para la experiencia completa.
# ------------------------------------------------------------------------------

# --- 1. Branding / Marca ---
APPOINTMENTS_BRAND="Acme Inc."
APPOINTMENTS_OWNER_NAME="Jane Doe"
APPOINTMENTS_OWNER_ROLE="Founder"
# EN: Receives "new appointment" alerts + used as Reply-To. ES: Recibe avisos + Reply-To.
APPOINTMENTS_OWNER_EMAIL="hello@example.com"
APPOINTMENTS_WEBSITE="https://example.com"
APPOINTMENTS_LINKEDIN=

# --- 2. Booking code prefix / Prefijo del código (2-4 letters) ---
APPOINTMENTS_REF_PREFIX=APT

# --- 3. Business time zone / Zona horaria (valid PHP tz, e.g. America/New_York) ---
APPOINTMENTS_TIMEZONE=Europe/Madrid

# --- 4. Schedule / Horario ---
APPOINTMENTS_DAYS_AHEAD=14
APPOINTMENTS_OPEN=09:30
APPOINTMENTS_CLOSE=18:00
APPOINTMENTS_MAX_ATTENDEES=10

# --- 5. Modalities / Modalidades (at least one true) ---
APPOINTMENTS_MODALITY_ONLINE=true
APPOINTMENTS_MODALITY_IN_PERSON=true

# --- 6. Admin panel password / Contraseña del panel (/panel) — SET A STRONG ONE ---
APPOINTMENTS_PANEL_PASSWORD=

# --- 7. Default theme / Tema por defecto: dark | light | auto ---
# EN: Visitors can toggle anyway (sun/moon); this is just the default.
# ES: El visitante puede cambiarlo igual (sol/luna); esto es solo el de partida.
APPOINTMENTS_THEME=dark

# ------------------------------------------------------------------------------
# Google Calendar + Meet (OPTIONAL / OPCIONAL)
# EN: Without these, online bookings still work but get NO auto Meet link and
#     the calendar won't sync. See docs/GOOGLE.md to get each value.
# ES: Sin esto, las citas online funcionan pero SIN enlace de Meet automático y
#     sin sincronizar el calendario. Mira docs/GOOGLE.md para sacar cada valor.
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_REDIRECT_URI=http://localhost

# ------------------------------------------------------------------------------
# Telegram bot (OPTIONAL / OPCIONAL)
# EN: Get instant alerts and confirm/reject bookings from your phone. Without
#     these, you manage everything from the /panel instead. See docs/TELEGRAM.md.
# ES: Recibe avisos al instante y confirma/rechaza citas desde el móvil. Sin
#     esto, gestionas todo desde el /panel. Mira docs/TELEGRAM.md.
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
